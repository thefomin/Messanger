{
	"compilerOptions": {
		"target": "ES2022",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"declaration": true,
		"removeComments": true,
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"sourceMap": true,
		"outDir": "./dist",
		"baseUrl": "./src",
		"paths": {
			"@/*": ["*"],
			"@prisma/__generated__": ["../prisma/__generated__"],
			"@prisma/__generated__/*": ["../prisma/__generated__/*"]
		},
		"incremental": true,
		"skipLibCheck": true,
		"strict": true
	}
}
